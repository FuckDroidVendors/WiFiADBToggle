<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/mediaTestTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/media_test_title"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/mediaTestHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/media_test_hint"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/mediaTestEvent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/media_test_event"
        android:layout_marginTop="12dp" />

    <TextView
        android:id="@+id/mediaTestCount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/media_test_count"
        android:layout_marginTop="4dp" />

    <Button
        android:id="@+id/mediaTestClose"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@android:string/ok"
        android:layout_marginTop="16dp" />
</LinearLayout>
